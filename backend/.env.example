# GitHub personal access token (needs repo, read:org scopes)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub username
GITHUB_USERNAME=your_github_username

# OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# How often to poll GitHub for newly assigned issues (seconds)
POLL_INTERVAL=300

# Comma-separated GitHub org names to watch.
# Only issues assigned to you inside these orgs will be processed.
# Example: WATCH_ORGS=stellar,drips-network
# Leave empty to watch ALL orgs (risky if you have other assignments).
WATCH_ORGS=

# Label required on an issue for Workman to pick it up.
# Defaults to "Stellar Wave" for Drips bounties. Leave empty to disable.
WATCH_LABEL=Stellar Wave

# Directory where repos are cloned. Defaults to backend/work/ (private, persistent).
# Do not use /tmp — it is world-readable and cleared on reboot.
WORKDIR=

# Dashboard auth token. If set, the WebSocket and /api/status endpoints require
# ?token=<value>. Leave empty to disable auth (local / trusted environments only).
# Must match VITE_DASHBOARD_TOKEN in the frontend .env.
DASHBOARD_TOKEN=

# Comma-separated allowed CORS origins.
# Defaults to http://localhost:5173,http://localhost:3000 when unset.
# MUST be set to your deployed frontend URL in production — leaving it
# unset or using * in production allows any website to query your API.
# Example: ALLOWED_ORIGINS=https://workman.vercel.app
ALLOWED_ORIGINS=
