# GitHub personal access token (needs repo, read:org scopes)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub username
GITHUB_USERNAME=your_github_username

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# How often to poll GitHub for newly assigned issues (seconds)
POLL_INTERVAL=300

# Comma-separated GitHub org names to watch.
# Only issues assigned to you inside these orgs will be processed.
# Example: WATCH_ORGS=stellar,drips-network
# Leave empty to watch ALL orgs (risky if you have other assignments).
WATCH_ORGS=

# Directory where repos are cloned before mounting into Docker
WORKDIR=/tmp/workman
