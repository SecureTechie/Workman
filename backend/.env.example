# GitHub personal access token (needs repo, read:org scopes)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub username
GITHUB_USERNAME=your_github_username

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Path to cookies.json exported from your browser after logging into drips.network
# Use a browser extension like "Cookie-Editor" to export as JSON
DRIPS_COOKIES_FILE=cookies.json

# How often to poll Drips for new assigned issues (seconds)
POLL_INTERVAL=300

# Directory where repos are cloned before mounting into Docker
WORKDIR=/tmp/workman


# 1. Install deps
  pip install -r requirements.txt
  playwright install chromium

  # 2. Configure
  cp .env.example .env
  # fill in GITHUB_TOKEN, GITHUB_USERNAME, ANTHROPIC_API_KEY

  # 3. Export your Drips cookies
  # Log into drips.network → use "Cookie-Editor" extension → Export as JSON → save as cookies.json

  # 4. Run
  python main.py --once    # test one cycle
  python main.py           # start the full loop